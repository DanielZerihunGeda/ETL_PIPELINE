COMPOSE_PROJECT_NAME=etl_pipeline

WAREHOUSE_POSTGRES_IMAGE=postgres:16
WAREHOUSE_DB=traffic_warehouse
WAREHOUSE_USER=warehouse
WAREHOUSE_PASSWORD=warehouse
WAREHOUSE_PORT=5432
WAREHOUSE_HOST=warehouse-postgres

AIRFLOW_BASE_IMAGE=apache/airflow:2.9.3-python3.11
AIRFLOW_IMAGE=etl-pipeline-airflow-dbt:local
AIRFLOW_VERSION=2.9.3
AIRFLOW_PYTHON_VERSION=3.11
AIRFLOW_UID=50000
AIRFLOW_DB_IMAGE=postgres:16
AIRFLOW_DB_NAME=airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_PORT=8080
AIRFLOW_FERNET_KEY=
AIRFLOW_WEBSERVER_SECRET_KEY=local-airflow-secret
AIRFLOW_ADMIN_USERNAME=airflow
AIRFLOW_ADMIN_PASSWORD=airflow
AIRFLOW_ADMIN_EMAIL=airflow@example.local
AIRFLOW_ADMIN_FIRSTNAME=Airflow
AIRFLOW_ADMIN_LASTNAME=Admin

REDIS_IMAGE=redis:7-alpine
REDASH_IMAGE=redash/redash:10.1.0.b50633
REDASH_DB_IMAGE=postgres:16
REDASH_DB_NAME=redash
REDASH_DB_USER=redash
REDASH_DB_PASSWORD=redash
REDASH_PORT=5000
REDASH_COOKIE_SECRET=local-redash-cookie-secret
REDASH_SECRET_KEY=local-redash-secret-key
REDASH_HOST=http://localhost:5000
REDASH_URL=http://localhost:5000
REDASH_API_KEY=
REDASH_DASHBOARD_IDS=
REDASH_EXPORT_DIR=redash/exports

LOCAL_DATA_PATH=./data
TRAJECTORY_DATA_PATH=/opt/airflow/data
TRAJECTORY_FILE_PATTERN=*.csv
TRAJECTORY_DELIMITER=;
DATASET_DATE=2026-01-01
DATASET_AREA=local
RUN_IDENTIFIER=manual
PIPELINE_ALERT_WEBHOOK_URL=
DBT_PROFILES_DIR=/opt/airflow/.dbt
DBT_PROJECT_DIR=/opt/airflow/dbt
DBT_TARGET=dev
DBT_POSTGRES_VERSION=1.8.2
